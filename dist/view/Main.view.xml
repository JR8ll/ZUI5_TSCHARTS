<Page>
    <layout:FixFlex id='chartFixFlex' fixContentSize="15vw" minFlexSize="250" vertical="false">
        <layout:fixContent>
            <Panel id="idPanel" class="panelStyle" expandable="false" expanded="true" headerText="Settings" width="auto" height="15vh">
                    <content>
                        <HBox class='settingsHBox'>
                            <VBox width="200px">
                                <Select id="idTypeSelect" selectedKey="{settings>/selectedChartType}" items="{settings>/chartTypes}">
                                    <items>
                                        <core:Item text="{settings>key}" key="{settings>value}"/>
                                    </items>
                                </Select>
                            </VBox>
                        </HBox>
                    </content>
                </Panel>
                <Panel expandable="false" expanded="true" headerText="Upper Chart Data" height="35vh">
            <up:UploadSet id="idUploadTop" uploadButtonInvisible="true"
                        fileTypes="csv" mediaTypes="text/csv" uploadUrl="../model/" multiple="false" showIcons="false"
                        uploadCompleted="onUpload" beforeItemAdded="onNewUpload" beforeItemRemoved="onDeleteFile" mode="None" noDataIllustrationType="NoChartData">
                        <up:illustratedMessage>
                            <IllustratedMessage title="{i18n>UploadNoDataText}" description="{i18n>DragDropDescription}" illustrationType="NoChartData"></IllustratedMessage>
                        </up:illustratedMessage>
            </up:UploadSet>
            </Panel>
            <Panel expandable="false" expanded="true" headerText="Lower Chart Data" height="35vh">
                <up:UploadSet id="idUploadBottom" uploadButtonInvisible="true"
                        fileTypes="csv" mediaTypes="text/csv" uploadUrl="../model/" multiple="false" 
                        uploadCompleted="onUpload" beforeItemAdded="onNewUpload" beforeItemRemoved="onDeleteFile" mode="None" noDataIllustrationType="NoChartData">
                 <up:illustratedMessage>
                    <IllustratedMessage title="{i18n>UploadNoDataText}" description="{i18n>DragDropDescription}" illustrationType="NoChartData"></IllustratedMessage>
                </up:illustratedMessage>
             </up:UploadSet>
            </Panel>
        </layout:fixContent>
        <layout:flexContent>
            <HBox>
                <VBox width="100%" height="100px">
                    <viz:VizFrame id="idVizFrameTop" uiConfig="{applicationSet:'fiori'}"
                        height='45vh' width="85vw" vizType="{settings>/selectedChartType}" > </viz:VizFrame>
                    <viz:VizFrame id="idVizFrameBottom" uiConfig="{applicationSet:'fiori'}"
                        height='45vh' width="85vw" vizType="{settings>/selectedChartType}" > </viz:VizFrame>     
                </VBox>
                <!-- <VBox width="30%" height="100%">
                    <viz:VizFrame id="chartSmall" height="100%" width="100%" ... />
                </VBox> -->
            </HBox>
        </layout:flexContent>
    </layout:FixFlex>
</Page>
</mvc:View>